    <a class="text-[20px] lg:text-[30px] font-space uppercase flex items-center justify-between text-white hover:text-white/60 transition-colors w-full lg:w-[350px] border-b border-white/20 pb-4" href="https://instagram.com/" target="_blank" rel="noopener" aria-label="Acessar Instagram de Mateus">
