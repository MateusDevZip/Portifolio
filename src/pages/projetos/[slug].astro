---
import { getCollection } from 'astro:content';
import ProjectLayout from '../../layouts/ProjectLayout.astro';
import Footer from '../../components/sections/Footer.astro';
import ProjectGallery from '../../components/ProjectGallery.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(project => ({
    params: { slug: project.slug },
    props: { project }
  }));
}

const { project } = Astro.props;
const { Content } = await project.render();

const allProjects = await getCollection('projects');
const currentIndex = allProjects.findIndex(p => p.slug === project.slug);
const nextProject = allProjects[(currentIndex + 1) % allProjects.length];
const prevProject = allProjects[(currentIndex - 1 + allProjects.length) % allProjects.length];

const baseUrl = import.meta.env.BASE_URL;
---

<ProjectLayout title={`${project.data.title} — Mateus`} description={project.data.description}>
  <!-- Project Header with Tabs (Fixed) -->
  <header class="fixed top-0 w-full z-50 bg-black/80 backdrop-blur-md border-b border-white/[0.08]">
    <div class="max-w-7xl mx-auto flex justify-between items-center px-8 h-20">
      <!-- Logo -->
      <a href={baseUrl} class="text-white/80 hover:text-white font-bold uppercase tracking-widest text-sm transition-colors">
        ← Mateus
      </a>

      <!-- Tabs Navigation (Hidden on Mobile) -->
      <nav class="hidden md:flex items-center gap-8">
        <button data-tab="visao-geral" class="text-blue-400 border-b-2 border-blue-400 pb-1 font-semibold text-sm uppercase tracking-wide transition-colors cursor-pointer">
          Overview
        </button>
        <button data-tab="stack" class="text-white/60 hover:text-white pb-1 font-semibold text-sm uppercase tracking-wide transition-colors cursor-pointer">
          Stack
        </button>
        <button data-tab="funcionalidades" class="text-white/60 hover:text-white pb-1 font-semibold text-sm uppercase tracking-wide transition-colors cursor-pointer">
          Features
        </button>
        <button id="tab-banco-dados" data-tab="banco-dados" class="text-white/60 hover:text-white pb-1 font-semibold text-sm uppercase tracking-wide transition-colors cursor-pointer">
          Database
        </button>
        <button data-tab="resultados" class="text-white/60 hover:text-white pb-1 font-semibold text-sm uppercase tracking-wide transition-colors cursor-pointer">
          Results
        </button>
      </nav>

      <!-- Live Button -->
      <div>
        {project.data.link && (
          <a href={project.data.link} target="_blank" rel="noopener noreferrer" class="text-white/60 hover:text-white transition-colors">
            <span class="text-lg">↗</span>
          </a>
        )}
      </div>
    </div>
  </header>

  <main class="relative z-10 pt-24">
    <!-- Hero Section -->
    <section class="px-8 lg:px-16 py-20 border-b border-white/[0.08]">
      <div class="max-w-7xl mx-auto">
        <!-- Breadcrumb -->
        <div class="flex items-center gap-3 font-mono text-sm tracking-widest text-white/40 uppercase mb-8">
          <span>{project.data.category}</span>
          <span class="w-8 h-[1px] bg-white/20"></span>
          <span>{project.data.year}</span>
        </div>

        <!-- Title -->
        <h1 class="text-[clamp(2.5rem,8vw,5rem)] font-black tracking-tighter text-white uppercase leading-[0.95] mb-12">
          {project.data.title}
        </h1>

        <!-- Tech Badges -->
        <div class="flex flex-wrap gap-3">
          {project.data.technologies && project.data.technologies.map((tech) => (
            <span class="px-4 py-1.5 rounded-full border border-white/10 text-xs font-mono bg-white/5 text-white/80 hover:bg-white/10 transition-colors">
              {tech}
            </span>
          ))}
        </div>
      </div>
    </section>

    <!-- Gallery Section -->
    <section class="w-full aspect-video relative overflow-hidden bg-gradient-to-b from-white/5 to-transparent">
      {project.data.images && project.data.images.length > 0 ? (
        <ProjectGallery images={project.data.images} projectTitle={project.data.title} />
      ) : (
        <div class="w-full h-full flex items-center justify-center bg-white/5">
          <div class="text-center">
            <div class="w-24 h-24 rounded-full mx-auto mb-6" style={{ backgroundColor: `${project.data.color}20` }}>
              <div class="w-full h-full flex items-center justify-center">
                <span class="text-4xl" style={{ color: project.data.color }}>📸</span>
              </div>
            </div>
            <p class="text-white/40 font-mono text-sm uppercase tracking-widest">No project imagery</p>
          </div>
        </div>
      )}
    </section>

    <!-- Content Section with Tabs and Sidebar -->
    <section class="px-8 lg:px-16 py-20">
      <div class="max-w-7xl mx-auto">
        <!-- Tab Bar (Mobile) -->
        <div class="md:hidden mb-12 border-b border-white/[0.08] pb-4">
          <div class="flex overflow-x-auto gap-4 -mx-8 px-8">
            <button data-tab="visao-geral" class="tab-button-mobile text-white/60 hover:text-white pb-2 font-semibold text-xs uppercase tracking-wide transition-colors cursor-pointer whitespace-nowrap">
              Overview
            </button>
            <button data-tab="stack" class="tab-button-mobile text-white/60 hover:text-white pb-2 font-semibold text-xs uppercase tracking-wide transition-colors cursor-pointer whitespace-nowrap">
              Stack
            </button>
            <button data-tab="funcionalidades" class="tab-button-mobile text-white/60 hover:text-white pb-2 font-semibold text-xs uppercase tracking-wide transition-colors cursor-pointer whitespace-nowrap">
              Features
            </button>
            <button data-tab="banco-dados" class="tab-button-mobile text-white/60 hover:text-white pb-2 font-semibold text-xs uppercase tracking-wide transition-colors cursor-pointer whitespace-nowrap">
              Database
            </button>
            <button data-tab="resultados" class="tab-button-mobile text-white/60 hover:text-white pb-2 font-semibold text-xs uppercase tracking-wide transition-colors cursor-pointer whitespace-nowrap">
              Results
            </button>
          </div>
        </div>

        <!-- Grid: Content + Sidebar -->
        <div class="grid lg:grid-cols-[1fr_340px] gap-16">
          <!-- Tab Panels -->
          <div class="space-y-8">
            <div id="panel-visao-geral" class="tab-panel prose prose-invert prose-headings:font-black prose-headings:text-white prose-p:text-white/80 prose-p:leading-relaxed prose-a:text-blue-400 prose-strong:text-white prose-code:text-blue-300">
              <!-- Visão Geral content will be inserted here -->
            </div>
            <div id="panel-stack" class="tab-panel hidden prose prose-invert prose-headings:font-black prose-headings:text-white prose-p:text-white/80 prose-p:leading-relaxed prose-a:text-blue-400 prose-strong:text-white prose-code:text-blue-300">
              <!-- Stack Técnico content will be inserted here -->
            </div>
            <div id="panel-funcionalidades" class="tab-panel hidden prose prose-invert prose-headings:font-black prose-headings:text-white prose-p:text-white/80 prose-p:leading-relaxed prose-a:text-blue-400 prose-strong:text-white prose-code:text-blue-300">
              <!-- Funcionalidades content will be inserted here -->
            </div>
            <div id="panel-banco-dados" class="tab-panel hidden prose prose-invert prose-headings:font-black prose-headings:text-white prose-p:text-white/80 prose-p:leading-relaxed prose-a:text-blue-400 prose-strong:text-white prose-code:text-blue-300">
              <!-- Banco de Dados content will be inserted here -->
            </div>
            <div id="panel-resultados" class="tab-panel hidden prose prose-invert prose-headings:font-black prose-headings:text-white prose-p:text-white/80 prose-p:leading-relaxed prose-a:text-blue-400 prose-strong:text-white prose-code:text-blue-300">
              <!-- Resultados content will be inserted here -->
            </div>
          </div>

          <!-- Sidebar -->
          <aside class="space-y-6">
            <!-- Project Info Card -->
            <div class="bg-white/5 border border-white/10 rounded-2xl p-6 backdrop-blur-sm">
              <h3 class="font-mono text-xs uppercase tracking-widest text-white/60 mb-4">Sobre o Projeto</h3>
              <div class="space-y-4">
                <div>
                  <p class="text-white/50 font-mono text-xs uppercase tracking-widest mb-1">Tipo</p>
                  <p class="text-white text-sm">{project.data.category}</p>
                </div>
                <div>
                  <p class="text-white/50 font-mono text-xs uppercase tracking-widest mb-1">Ano</p>
                  <p class="text-white text-sm">{project.data.year}</p>
                </div>
              </div>
            </div>

            <!-- Technologies Card -->
            <div class="bg-white/5 border border-white/10 rounded-2xl p-6 backdrop-blur-sm">
              <h3 class="font-mono text-xs uppercase tracking-widest text-white/60 mb-4">Stack</h3>
              <div class="space-y-2">
                {project.data.technologies && project.data.technologies.map((tech) => (
                  <div class="flex items-center gap-2">
                    <span class="w-1.5 h-1.5 rounded-full bg-blue-400"></span>
                    <span class="text-white/80 text-sm font-mono">{tech}</span>
                  </div>
                ))}
              </div>
            </div>

            <!-- Links Card -->
            <div class="bg-white/5 border border-white/10 rounded-2xl p-6 backdrop-blur-sm">
              <h3 class="font-mono text-xs uppercase tracking-widest text-white/60 mb-4">Links</h3>
              <div class="space-y-3">
                {project.data.link && (
                  <a href={project.data.link} target="_blank" rel="noopener noreferrer" class="block text-blue-400 hover:text-blue-300 text-sm font-mono transition-colors">
                    View Live ↗
                  </a>
                )}
                <a href="https://github.com/DevZipMateus" target="_blank" rel="noopener noreferrer" class="block text-white/70 hover:text-white text-sm font-mono transition-colors">
                  GitHub ↗
                </a>
              </div>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <!-- Navigation to Other Projects -->
    <section class="border-t border-white/[0.08] px-8 lg:px-16 py-20">
      <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
          <!-- Previous Project -->
          {prevProject && (
            <a href={`${baseUrl}projetos/${prevProject.slug}`} class="group">
              <p class="text-white/30 font-mono text-xs uppercase tracking-widest mb-4">← Previous Project</p>
              <h3 class="text-2xl md:text-3xl font-bold text-white uppercase group-hover:-translate-x-1 transition-transform">
                {prevProject.data.title}
              </h3>
            </a>
          )}

          <!-- Next Project -->
          {nextProject && (
            <a href={`${baseUrl}projetos/${nextProject.slug}`} class="group md:text-right">
              <p class="text-white/30 font-mono text-xs uppercase tracking-widest mb-4">Next Project →</p>
              <h3 class="text-2xl md:text-3xl font-bold text-white uppercase group-hover:translate-x-1 transition-transform">
                {nextProject.data.title}
              </h3>
            </a>
          )}
        </div>
      </div>
    </section>
  </main>

  <Footer />

  <!-- Hidden container for rendering markdown -->
  <div id="content-container" class="hidden">
    <article class="prose prose-invert">
      <Content />
    </article>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const contentContainer = document.getElementById('content-container');

      // Define section mapping with expanded matchers for different markdown variations
      const SECTION_MAP = {
        'visão geral': 'panel-visao-geral',
        'stack técnico': 'panel-stack',
        'tecnologias utilizadas': 'panel-stack',
        'funcionalidades': 'panel-funcionalidades',
        'funcionalidades principais': 'panel-funcionalidades',
        'banco de dados': 'panel-banco-dados',
        'resultados': 'panel-resultados',
        'resultados & impacto': 'panel-resultados',
        'impacto': 'panel-resultados',
      };

      if (contentContainer) {
        const article = contentContainer.querySelector('article');
        if (article) {
          const h2Headings = Array.from(article.querySelectorAll('h2'));
          const overflowContent = []; // For sections that don't match

          h2Headings.forEach((heading) => {
            const content = [];
            let currentNode = heading.nextElementSibling;

            // Collect content until next h2
            while (currentNode && currentNode.tagName !== 'H2') {
              content.push(currentNode.cloneNode(true));
              currentNode = currentNode.nextElementSibling;
            }

            const headingText = heading.textContent.toLowerCase().trim();
            let targetPanel = null;

            // Find matching panel
            for (const [key, panelId] of Object.entries(SECTION_MAP)) {
              if (headingText.includes(key)) {
                targetPanel = document.getElementById(panelId);
                break;
              }
            }

            if (targetPanel && content.length > 0) {
              content.forEach(element => {
                targetPanel.appendChild(element.cloneNode(true));
              });
            } else if (content.length > 0) {
              // Store overflow content for visão-geral
              overflowContent.push(...content);
            }
          });

          // Add overflow content to visão-geral if any
          if (overflowContent.length > 0) {
            const visaoGeralPanel = document.getElementById('panel-visao-geral');
            const separator = document.createElement('hr');
            separator.className = 'my-8 border-white/10';
            visaoGeralPanel.appendChild(separator);
            overflowContent.forEach(element => {
              visaoGeralPanel.appendChild(element.cloneNode(true));
            });
          }
        }
      }

      // Hide empty tabs
      ['stack', 'banco-dados', 'funcionalidades', 'resultados'].forEach(id => {
        const panel = document.getElementById(`panel-${id}`);
        const tab = document.querySelector(`[data-tab="${id}"]`);
        const mobileTab = document.querySelector(`[data-tab="${id}"].tab-button-mobile`);

        if (panel && tab && panel.children.length === 0) {
          tab.style.display = 'none';
          if (mobileTab) mobileTab.style.display = 'none';
        }
      });

      // Tab functionality
      const allTabButtons = document.querySelectorAll('[data-tab]');

      allTabButtons.forEach(button => {
        button.addEventListener('click', () => {
          const targetTab = button.getAttribute('data-tab');

          // Hide all panels
          document.querySelectorAll('.tab-panel').forEach(p => {
            p.classList.add('hidden');
          });

          // Remove active state from all buttons
          allTabButtons.forEach(b => {
            b.classList.remove('active');
            b.style.borderBottomColor = 'transparent';
            b.style.color = 'rgb(107, 114, 128)';
          });

          // Show selected panel
          const selectedPanel = document.getElementById(`panel-${targetTab}`);
          if (selectedPanel) {
            selectedPanel.classList.remove('hidden');
          }

          // Set active state on clicked button
          button.classList.add('active');
          button.style.borderBottomColor = '#60a5fa';
          button.style.color = '#60a5fa';
        });
      });

      // Initialize Lenis smooth scroll
      if (typeof Lenis !== 'undefined') {
        const lenis = new Lenis({
          duration: 1.2,
          easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
          direction: 'vertical',
          gestureDirection: 'vertical',
          smooth: true,
          mouseMultiplier: 1,
          smoothTouch: false,
          touchMultiplier: 2,
          infinite: false,
        });

        function raf(time) {
          lenis.raf(time);
          requestAnimationFrame(raf);
        }
        requestAnimationFrame(raf);
      }

      // Custom cursor
      const customCursor = document.querySelector('.custom-cursor');
      const cursorFollower = document.querySelector('.cursor-follower');

      if (customCursor && cursorFollower) {
        let mouseX = 0;
        let mouseY = 0;
        let followerX = 0;
        let followerY = 0;

        document.addEventListener('mousemove', (e) => {
          mouseX = e.clientX;
          mouseY = e.clientY;

          customCursor.style.left = mouseX + 'px';
          customCursor.style.top = mouseY + 'px';
          customCursor.classList.add('visible');

          cursorFollower.classList.add('visible');
        });

        function animateFollower() {
          followerX += (mouseX - followerX) * 0.2;
          followerY += (mouseY - followerY) * 0.2;

          cursorFollower.style.left = followerX + 'px';
          cursorFollower.style.top = followerY + 'px';

          requestAnimationFrame(animateFollower);
        }

        animateFollower();

        document.addEventListener('mouseleave', () => {
          customCursor.classList.remove('visible');
          cursorFollower.classList.remove('visible');
        });

        document.addEventListener('touchstart', () => {
          customCursor.classList.remove('visible');
          cursorFollower.classList.remove('visible');
        });
      }
    });
  </script>
</ProjectLayout>
