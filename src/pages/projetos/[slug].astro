---
import { getCollection } from 'astro:content';
import ProjectLayout from '../../layouts/ProjectLayout.astro';
import Footer from '../../components/sections/Footer.astro';
import ProjectGallery from '../../components/ProjectGallery.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(project => ({
    params: { slug: project.slug },
    props: { project }
  }));
}

const { project } = Astro.props;
const { Content } = await project.render();

const allProjects = await getCollection('projects');
const currentIndex = allProjects.findIndex(p => p.slug === project.slug);
const nextProject = allProjects[(currentIndex + 1) % allProjects.length];
const prevProject = allProjects[(currentIndex - 1 + allProjects.length) % allProjects.length];

const baseUrl = import.meta.env.BASE_URL;
---

<ProjectLayout title={`${project.data.title} — Mateus`} description={project.data.description}>
  <!-- TopAppBar -->
  <header class="fixed top-0 w-full z-50 bg-[#0b1326]/80 backdrop-blur-md shadow-[0_20px_50px_rgba(0,46,106,0.15)]">
    <div class="max-w-[1920px] mx-auto flex justify-between items-center px-8 h-20">
      <div class="text-xl font-black tracking-tighter text-slate-50 uppercase">
        {project.data.title}
      </div>
      <nav class="hidden md:flex items-center gap-8">
        <button data-tab="visao-geral" class="text-slate-400 font-medium hover:text-blue-400 transition-colors duration-300 cursor-pointer active-tab">Overview</button>
        <button data-tab="stack" class="text-slate-400 font-medium hover:text-blue-400 transition-colors duration-300 cursor-pointer">Stack</button>
        <button data-tab="funcionalidades" class="text-slate-400 font-medium hover:text-blue-400 transition-colors duration-300 cursor-pointer">Features</button>
        <button id="tab-banco-dados" data-tab="banco-dados" class="text-slate-400 font-medium hover:text-blue-400 transition-colors duration-300 cursor-pointer">Database</button>
        <button data-tab="resultados" class="text-slate-400 font-medium hover:text-blue-400 transition-colors duration-300 cursor-pointer">Results</button>
      </nav>
      <div class="flex items-center gap-4">
        {project.data.link && (
          <a href={project.data.link} target="_blank" rel="noopener noreferrer" class="active:scale-95 transition-transform duration-200">
            <span class="material-symbols-outlined text-slate-400 hover:text-blue-400">open_in_new</span>
          </a>
        )}
        <a href={baseUrl} class="active:scale-95 transition-transform duration-200">
          <span class="material-symbols-outlined text-slate-400 hover:text-blue-400">home</span>
        </a>
      </div>
    </div>
  </header>

  <main class="pt-32 pb-24 monolith-gradient min-h-screen">
    <!-- Hero Section -->
    <section class="max-w-7xl mx-auto px-8 mb-20">
      <div class="flex flex-col md:flex-row justify-between items-end gap-8 border-b border-outline-variant/20 pb-12">
        <div class="space-y-4">
          <div class="flex items-center gap-3 font-mono text-sm tracking-widest text-primary uppercase">
            <span>{project.data.category}</span>
            <span class="w-8 h-[1px] bg-outline-variant/50"></span>
            <span>{project.data.year}</span>
          </div>
          <h1 class="text-7xl md:text-8xl font-black tracking-tighter text-slate-50">
            {project.data.title}
          </h1>
        </div>
        <div class="flex flex-wrap gap-2">
          {project.data.technologies && project.data.technologies.map((tech) => (
            <span class="px-4 py-1.5 rounded-full border border-outline-variant/30 text-xs font-mono bg-surface-container-low text-on-surface">
              {tech}
            </span>
          ))}
        </div>
      </div>
    </section>

    <!-- Project Media -->
    <section class="max-w-7xl mx-auto px-8 mb-24">
      <div class="aspect-video w-full rounded-xl overflow-hidden bg-surface-container-low relative group">
        {project.data.images && project.data.images.length > 0 ? (
          <ProjectGallery images={project.data.images} projectTitle={project.data.title} />
        ) : (
          <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-surface-container to-surface-container-low">
            <div class="text-center">
              <span class="material-symbols-outlined text-6xl text-primary/50 mb-4 block">image_not_supported</span>
              <p class="text-slate-400 font-mono text-sm uppercase tracking-widest">No imagery available</p>
            </div>
          </div>
        )}
        <div class="absolute inset-0 bg-gradient-to-t from-[#0b1326] via-transparent to-transparent pointer-events-none"></div>
      </div>
    </section>

    <!-- Tabs Navigation -->
    <section class="max-w-7xl mx-auto px-8 mb-16">
      <div class="flex flex-wrap gap-x-12 gap-y-6 border-b border-outline-variant/10">
        <button data-tab="visao-geral" class="pb-4 text-blue-500 border-b-2 border-blue-500 font-bold text-lg tracking-tight uppercase cursor-pointer active-tab-btn">Visão Geral</button>
        <button data-tab="stack" class="pb-4 text-slate-500 hover:text-slate-300 transition-colors font-bold text-lg tracking-tight uppercase cursor-pointer">Stack Técnico</button>
        <button data-tab="funcionalidades" class="pb-4 text-slate-500 hover:text-slate-300 transition-colors font-bold text-lg tracking-tight uppercase cursor-pointer">Funcionalidades</button>
        <button id="btn-banco-dados" data-tab="banco-dados" class="pb-4 text-slate-500 hover:text-slate-300 transition-colors font-bold text-lg tracking-tight uppercase cursor-pointer">Banco de Dados</button>
        <button data-tab="resultados" class="pb-4 text-slate-500 hover:text-slate-300 transition-colors font-bold text-lg tracking-tight uppercase cursor-pointer">Resultados</button>
      </div>
    </section>

    <!-- Content Canvas (Asymmetric Layout) -->
    <section class="max-w-7xl mx-auto px-8 grid grid-cols-1 md:grid-cols-12 gap-16">
      <div class="md:col-span-8 space-y-12">
        <!-- Tab Panels -->
        <div id="panel-visao-geral" class="tab-panel prose prose-invert prose-headings:font-bold prose-headings:text-slate-50 prose-p:text-slate-300 prose-p:leading-relaxed prose-a:text-blue-400">
          <!-- Visão Geral content will be inserted here -->
        </div>
        <div id="panel-stack" class="tab-panel hidden prose prose-invert prose-headings:font-bold prose-headings:text-slate-50 prose-p:text-slate-300 prose-p:leading-relaxed prose-a:text-blue-400">
          <!-- Stack Técnico content will be inserted here -->
        </div>
        <div id="panel-funcionalidades" class="tab-panel hidden space-y-8">
          <!-- Funcionalidades content will be inserted here -->
        </div>
        <div id="panel-banco-dados" class="tab-panel hidden prose prose-invert prose-headings:font-bold prose-headings:text-slate-50 prose-p:text-slate-300 prose-p:leading-relaxed prose-a:text-blue-400">
          <!-- Banco de Dados content will be inserted here -->
        </div>
        <div id="panel-resultados" class="tab-panel hidden prose prose-invert prose-headings:font-bold prose-headings:text-slate-50 prose-p:text-slate-300 prose-p:leading-relaxed prose-a:text-blue-400">
          <!-- Resultados content will be inserted here -->
        </div>
      </div>

      <!-- Sidebar -->
      <div class="md:col-span-4 space-y-8">
        <div class="p-10 bg-surface-container-highest/30 rounded-2xl backdrop-blur-sm border border-outline-variant/10">
          <h4 class="text-slate-50 font-bold mb-6 flex items-center gap-2">
            <span class="material-symbols-outlined text-blue-500">info</span>
            Project Details
          </h4>
          <div class="space-y-4">
            <div>
              <p class="text-xs font-mono uppercase text-slate-500 tracking-tighter mb-2">Category</p>
              <p class="text-slate-300">{project.data.category}</p>
            </div>
            <div>
              <p class="text-xs font-mono uppercase text-slate-500 tracking-tighter mb-2">Year</p>
              <p class="text-slate-300">{project.data.year}</p>
            </div>
            <div>
              <p class="text-xs font-mono uppercase text-slate-500 tracking-tighter mb-2">Technologies</p>
              <div class="flex flex-wrap gap-2">
                {project.data.technologies && project.data.technologies.slice(0, 3).map((tech) => (
                  <span class="px-2 py-1 rounded text-xs bg-surface-container border border-outline-variant/20 text-slate-300 font-mono">
                    {tech}
                  </span>
                ))}
              </div>
            </div>
          </div>
        </div>

        <div class="p-10 bg-surface-container-highest/30 rounded-2xl backdrop-blur-sm border border-outline-variant/10">
          <h4 class="text-slate-50 font-bold mb-6 flex items-center gap-2">
            <span class="material-symbols-outlined text-secondary">link</span>
            Links
          </h4>
          <div class="space-y-3">
            {project.data.link && (
              <a href={project.data.link} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-blue-400 hover:text-blue-300 text-sm font-mono transition-colors">
                <span class="material-symbols-outlined text-sm">open_in_new</span>
                View Live
              </a>
            )}
            <a href="https://github.com/DevZipMateus" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-slate-400 hover:text-slate-300 text-sm font-mono transition-colors">
              <span class="material-symbols-outlined text-sm">code</span>
              GitHub
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Features Grid (Bento Style) - Only show for projects with funcionalidades -->
    <div id="features-section" class="hidden">
      <section class="max-w-7xl mx-auto px-8 mt-32">
        <h2 class="text-xs font-mono uppercase tracking-[0.4em] text-slate-500 mb-12 text-center">Core Functionalities</h2>
        <div id="features-grid" class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <!-- Features will be extracted from funcionalidades panel -->
        </div>
      </section>
    </div>

    <!-- Project Navigation -->
    <section class="max-w-7xl mx-auto px-8 mt-48 border-t border-outline-variant/20 pt-12">
      <div class="flex flex-col md:flex-row justify-between gap-12">
        {prevProject && (
          <a href={`${baseUrl}projetos/${prevProject.slug}`} class="group">
            <span class="text-xs font-mono text-slate-500 uppercase tracking-widest block mb-4">Previous Project</span>
            <div class="flex items-center gap-4">
              <span class="material-symbols-outlined text-slate-500 group-hover:text-blue-500 group-hover:-translate-x-2 transition-all">arrow_back</span>
              <span class="text-2xl font-bold text-slate-50 group-hover:text-blue-500 transition-colors">{prevProject.data.title}</span>
            </div>
          </a>
        )}
        {nextProject && (
          <a href={`${baseUrl}projetos/${nextProject.slug}`} class="group md:text-right">
            <span class="text-xs font-mono text-slate-500 uppercase tracking-widest block mb-4">Next Project</span>
            <div class="flex items-center justify-end gap-4">
              <span class="text-2xl font-bold text-slate-50 group-hover:text-blue-500 transition-colors">{nextProject.data.title}</span>
              <span class="material-symbols-outlined text-slate-500 group-hover:text-blue-500 group-hover:translate-x-2 transition-all">arrow_forward</span>
            </div>
          </a>
        )}
      </div>
    </section>
  </main>

  <Footer />

  <!-- Hidden container for rendering markdown -->
  <div id="content-container" class="hidden">
    <article class="prose prose-invert">
      <Content />
    </article>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const contentContainer = document.getElementById('content-container');

      const SECTION_MAP = {
        'visão geral': 'panel-visao-geral',
        'stack técnico': 'panel-stack',
        'tecnologias utilizadas': 'panel-stack',
        'funcionalidades': 'panel-funcionalidades',
        'funcionalidades principais': 'panel-funcionalidades',
        'banco de dados': 'panel-banco-dados',
        'resultados': 'panel-resultados',
        'resultados & impacto': 'panel-resultados',
        'impacto': 'panel-resultados',
      };

      if (contentContainer) {
        const article = contentContainer.querySelector('article');
        if (article) {
          const h2Headings = Array.from(article.querySelectorAll('h2'));
          const overflowContent = [];

          h2Headings.forEach((heading) => {
            const content = [];
            let currentNode = heading.nextElementSibling;

            while (currentNode && currentNode.tagName !== 'H2') {
              content.push(currentNode.cloneNode(true));
              currentNode = currentNode.nextElementSibling;
            }

            const headingText = heading.textContent.toLowerCase().trim();
            let targetPanel = null;

            for (const [key, panelId] of Object.entries(SECTION_MAP)) {
              if (headingText.includes(key)) {
                targetPanel = document.getElementById(panelId);
                break;
              }
            }

            if (targetPanel && content.length > 0) {
              content.forEach(element => {
                targetPanel.appendChild(element.cloneNode(true));
              });
            } else if (content.length > 0) {
              overflowContent.push(...content);
            }
          });

          if (overflowContent.length > 0) {
            const visaoGeralPanel = document.getElementById('panel-visao-geral');
            const separator = document.createElement('hr');
            separator.className = 'my-8 border-outline-variant/20';
            visaoGeralPanel.appendChild(separator);
            overflowContent.forEach(element => {
              visaoGeralPanel.appendChild(element.cloneNode(true));
            });
          }
        }
      }

      // Hide empty tabs
      ['stack', 'banco-dados', 'funcionalidades', 'resultados'].forEach(id => {
        const panel = document.getElementById(`panel-${id}`);
        const tab = document.querySelector(`[data-tab="${id}"]`);
        const mobileTab = document.querySelector(`#tab-${id}`);
        const btnTab = document.querySelector(`#btn-${id}`);

        if (panel && tab && panel.children.length === 0) {
          tab.style.display = 'none';
          if (mobileTab) mobileTab.style.display = 'none';
          if (btnTab) btnTab.style.display = 'none';
        }
      });

      // Tab functionality
      const allTabButtons = document.querySelectorAll('[data-tab]');

      allTabButtons.forEach(button => {
        button.addEventListener('click', () => {
          const targetTab = button.getAttribute('data-tab');

          document.querySelectorAll('.tab-panel').forEach(p => {
            p.classList.add('hidden');
          });

          document.querySelectorAll('[data-tab]').forEach(b => {
            b.classList.remove('text-blue-500', 'border-b-2', 'border-blue-500', 'active-tab', 'active-tab-btn');
            b.classList.add('text-slate-400', 'text-slate-500');
          });

          const selectedPanel = document.getElementById(`panel-${targetTab}`);
          if (selectedPanel) {
            selectedPanel.classList.remove('hidden');
          }

          button.classList.remove('text-slate-400', 'text-slate-500');
          button.classList.add('text-blue-500', 'border-b-2', 'border-blue-500');
        });
      });

      // Lenis smooth scroll
      if (typeof Lenis !== 'undefined') {
        const lenis = new Lenis({
          duration: 1.2,
          easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
          direction: 'vertical',
          gestureDirection: 'vertical',
          smooth: true,
          mouseMultiplier: 1,
          smoothTouch: false,
          touchMultiplier: 2,
          infinite: false,
        });

        function raf(time) {
          lenis.raf(time);
          requestAnimationFrame(raf);
        }
        requestAnimationFrame(raf);
      }

      // Custom cursor
      const customCursor = document.querySelector('.custom-cursor');
      const cursorFollower = document.querySelector('.cursor-follower');

      if (customCursor && cursorFollower) {
        let mouseX = 0;
        let mouseY = 0;
        let followerX = 0;
        let followerY = 0;

        document.addEventListener('mousemove', (e) => {
          mouseX = e.clientX;
          mouseY = e.clientY;

          customCursor.style.left = mouseX + 'px';
          customCursor.style.top = mouseY + 'px';
          customCursor.classList.add('visible');

          cursorFollower.classList.add('visible');
        });

        function animateFollower() {
          followerX += (mouseX - followerX) * 0.2;
          followerY += (mouseY - followerY) * 0.2;

          cursorFollower.style.left = followerX + 'px';
          cursorFollower.style.top = followerY + 'px';

          requestAnimationFrame(animateFollower);
        }

        animateFollower();

        document.addEventListener('mouseleave', () => {
          customCursor.classList.remove('visible');
          cursorFollower.classList.remove('visible');
        });

        document.addEventListener('touchstart', () => {
          customCursor.classList.remove('visible');
          cursorFollower.classList.remove('visible');
        });
      }
    });
  </script>
</ProjectLayout>
