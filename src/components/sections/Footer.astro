<script>
  // Footer animation on scroll
  if (typeof gsap !== 'undefined' && typeof ScrollTrigger !== 'undefined') {
    const footer = document.querySelector('section[aria-label="Projetos selecionados"]')?.nextElementSibling;
    if (footer) {
      gsap.to(footer, {
        scrollTrigger: {
          trigger: footer,
          start: 'top 80%',
          toggleActions: 'play none none none'
        },
        duration: 0.8,
        y: 0,
        opacity: 1
      });
    }
  }
</script>
