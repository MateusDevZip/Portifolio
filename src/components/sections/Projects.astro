---
import { getCollection } from 'astro:content';
const projects = await getCollection('projects');
const sortedProjects = projects.sort((a, b) => b.data.year - a.data.year);
---

<section id="projects" class="projects-split px-[30px] lg:px-[60px] py-[100px] lg:py-[150px] relative z-10" aria-label="Projetos selecionados">
  <div class="grid lg:grid-cols-2 gap-12 lg:gap-24">

    <!-- Left: Project Names -->
    <div class="lg:sticky lg:top-[100px] xl:top-[120px] lg:self-start">
      <div class="flex items-end justify-between mb-4">
        <span id="project-counter" class="project-counter">01</span>
        <span class="text-white/20 font-space text-sm tracking-widest">/ {sortedProjects.length.toString().padStart(2, '0')}</span>
      </div>
      <div class="split-title flex items-center gap-3 mb-12">
        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
        <h2 class="uppercase text-white font-space tracking-widest text-[14px]">Trabalhos Selecionados</h2>
      </div>

      <div class="space-y-4" id="project-links">
        {sortedProjects.map((project, idx) => (
          <a href={`./projetos/${project.slug}`} class="split-project-item flex justify-between items-center py-4 pl-6 cursor-pointer group" class:list={{ active: idx === 0 }}>
            <div class="flex-1">
              <div class="flex items-center gap-3 mb-2">
                <span class="text-white/40 text-xs font-space tracking-wider block">{project.data.year}</span>
                <div class={`w-2 h-2 rounded-full animate-pulse`} style={{ backgroundColor: project.data.color }}></div>
              </div>
              <h3 class="text-[32px] md:text-[40px] font-bold text-white mb-1 uppercase group-hover:translate-x-2 transition-transform">{project.data.title}</h3>
              <p class="text-white/50 text-sm font-space">{project.data.category}</p>
            </div>
          </a>
        ))}
      </div>
    </div>

    <!-- Right: Previews -->
    <div class="split-preview space-y-16 lg:space-y-32" id="project-previews">
      {sortedProjects.map((project, idx) => (
        <div class={`project-preview-item project-card h-[60vh] lg:h-[75vh] w-full rounded-3xl bg-neutral-900 relative p-8 flex items-end overflow-hidden group`} class:list={{ active: idx === 0 }}>
          <div class="project-image absolute inset-0" style={{ backgroundColor: `${project.data.color}30` }}></div>
          <div class="absolute top-0 right-0 w-64 h-64 rounded-full filter blur-[100px] opacity-20" style={{ backgroundColor: project.data.color }}></div>
          <div class="relative z-20">
            <h4 class="text-2xl font-bold text-white mb-2">{project.data.title}</h4>
            <p class="text-white/80 text-lg md:text-xl font-space mb-8 max-w-md line-clamp-3">{project.data.description}</p>
            <a href={`./projetos/${project.slug}`} class="inline-flex items-center gap-3 px-6 py-3 rounded-full border border-white/20 hover:bg-white hover:text-black transition-colors text-white font-space font-medium text-sm">
              Ver Projeto <span class="text-lg">↗</span>
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  // Projects scroll spy animation
  if (typeof gsap !== 'undefined' && typeof ScrollTrigger !== 'undefined') {
    const projectItems = document.querySelectorAll('.split-project-item');
    const projectPreviews = document.querySelectorAll('.project-preview-item');
    const counter = document.getElementById('project-counter');

    projectItems.forEach((item, idx) => {
      item.addEventListener('mouseenter', () => {
        // Update counter
        if (counter) {
          counter.textContent = (idx + 1).toString().padStart(2, '0');
        }

        // Update active states
        projectItems.forEach(el => el.classList.remove('active'));
        projectPreviews.forEach(el => el.classList.remove('active'));
        item.classList.add('active');
        if (projectPreviews[idx]) projectPreviews[idx].classList.add('active');

        // Animate preview
        if (projectPreviews[idx]) {
          gsap.from(projectPreviews[idx], {
            opacity: 0,
            y: 20,
            duration: 0.3
          });
        }
      });
    });
  }
</script>

<style>
  .split-project-item {
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    transition: border-color 0.3s ease;
  }

  .split-project-item:hover {
    border-bottom-color: rgba(255, 255, 255, 0.3);
  }

  .split-project-item.active {
    border-bottom-color: rgba(255, 255, 255, 0.5);
  }

  .project-card {
    transition: transform 0.3s ease;
  }

  .project-card.active {
    transform: scale(1);
  }
</style>
