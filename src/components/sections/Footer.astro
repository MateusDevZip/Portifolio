    <a class="uppercase inline-block hover:bg-white hover:text-black transition-colors text-center text-white text-[20px] lg:text-[30px] rounded-full px-10 py-4 border border-white" href="mailto:matdasilvapinto@gmail.com">
      Entre em contato
    </a>
  </div>

  <div class="flex flex-col w-full lg:w-auto gap-6 lg:gap-10">
    <a class="text-[20px] lg:text-[30px] font-space uppercase flex items-center justify-between text-white hover:text-white/60 transition-colors w-full lg:w-[350px] border-b border-white/20 pb-4" href="https://www.linkedin.com/in/mateusdsp/" target="_blank" rel="noopener" aria-label="Acessar LinkedIn de Mateus">
      LinkedIn <span class="font-syne">↗</span>
    </a>
    <a class="text-[20px] lg:text-[30px] font-space uppercase flex items-center justify-between text-white hover:text-white/60 transition-colors w-full lg:w-[350px] border-b border-white/20 pb-4" href="https://github.com/MateusDevZip" target="_blank" rel="noopener" aria-label="Acessar GitHub de Mateus">
