---
---
<section class="hero-section flex items-center h-screen relative px-[30px] lg:px-[60px] z-10">
  <div class="w-full">
    <h1 class="text-heading font-archivo text-[50px] leading-[100%] md:text-[100px] xl:text-[140px] uppercase text-white mb-8" id="hero-title">
      <div class="overflow-hidden"><span class="block will-change-transform opacity-0">Full-Stack</span></div>
      <div class="overflow-hidden"><span class="block will-change-transform ml-0 md:ml-20 opacity-0">Developer</span></div>
      <div class="overflow-hidden"><span class="block will-change-transform text-[30px] md:text-[50px] xl:text-[70px] text-white/60 opacity-0">Martech</span></div>
    </h1>
  </div>

  <div class="absolute left-0 bottom-[60px] right-0 flex items-end lg:items-start justify-between px-[30px] lg:px-[60px]">
    <div class="hidden lg:flex w-[120px] h-[120px] items-center justify-center relative spin-text cursor-pointer" aria-label="Rolar para baixo">
      <svg viewBox="0 0 100 100" width="100" height="100" class="animate-spin-slow text-white fill-current">
        <path id="circlePath" d="M 50, 50 m -37, 0 a 37,37 0 1,1 74,0 a 37,37 0 1,1 -74,0" fill="none"></path>
        <text class="text-[11px] uppercase tracking-[6px] font-space font-medium">
          <textPath href="#circlePath">Scroll Down • Scroll Down •</textPath>
        </text>
      </svg>
      <div class="absolute w-4 h-4 rounded-full bg-white"></div>
    </div>
  </div>
</section>

<script>
  // Hero reveal animation
  if (typeof gsap !== 'undefined') {
    const timeline = gsap.timeline();

    // Animate hero title spans
    const titleSpans = document.querySelectorAll('#hero-title span.block');
    if (titleSpans.length > 0) {
      titleSpans.forEach((span) => {
        timeline.to(span, {
          opacity: 1,
          y: 0,
          duration: 0.8,
          ease: 'power4.out'
        }, 0.1);
      });
    }

    // Animate scroll indicator
    const scrollIndicator = document.querySelector('.spin-text');
    if (scrollIndicator) {
      gsap.to(scrollIndicator, {
        y: 10,
        duration: 1.5,
        repeat: -1,
        yoyo: true,
        ease: 'power1.inOut'
      });
    }
  }
</script>
