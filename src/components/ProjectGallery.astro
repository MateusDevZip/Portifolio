---
import { resolveAssetPath } from '../utils/imagePaths';

interface Props {
  images?: string[];
  projectTitle: string;
}

const { images = [], projectTitle } = Astro.props;
const resolvedImages = images?.map(img => resolveAssetPath(img)) || [];

---

<div class="w-full mb-16">
    <div class="relative w-full rounded-3xl overflow-hidden bg-white/5 backdrop-blur-sm border border-white/10">
      <!-- Main Image -->
      <div class="relative w-full aspect-video bg-neutral-900 overflow-hidden">
        <img
          id="gallery-main-image"
          src={resolvedImages[0]}
          alt={projectTitle}
          class="w-full h-full object-cover"
        />
      </div>

      <!-- Thumbnails Navigation -->
      {resolvedImages.length > 1 && (
        <div class="p-4 border-t border-white/10 bg-black/40">
          <div class="flex gap-3 overflow-x-auto pb-2">
            {resolvedImages.map((image, index) => (
              <button
                class={`gallery-thumb flex-shrink-0 w-20 h-20 rounded-lg overflow-hidden border-2 transition-colors cursor-pointer ${
                  index === 0 ? 'border-white/60' : 'border-white/20 hover:border-white/40'
                }`}
                data-index={index}
                data-src={image}
                aria-label={`Imagem ${index + 1}`}
              >
                <img src={image} alt={`${projectTitle} ${index + 1}`} class="w-full h-full object-cover" />
              </button>
            ))}
          </div>
        </div>
      )}

      <!-- Image Counter -->
      {resolvedImages.length > 1 && (
        <div class="absolute top-4 right-4 bg-black/60 backdrop-blur-sm px-4 py-2 rounded-full text-white/80 text-sm font-space">
          <span id="image-counter">1</span> / {resolvedImages.length}
        </div>
      )}
    </div>
  </div>

<script>
  document.querySelectorAll('.gallery-thumb').forEach((thumb, index) => {
    thumb.addEventListener('click', () => {
      const mainImage = document.getElementById('gallery-main-image') as HTMLImageElement;
      const counter = document.getElementById('image-counter');
      const src = thumb.getAttribute('data-src');

      if (mainImage && src) {
        mainImage.src = src;

        if (counter) {
          counter.textContent = String(index + 1);
        }

        // Update active border
        document.querySelectorAll('.gallery-thumb').forEach((t, i) => {
          if (i === index) {
            t.classList.remove('border-white/20', 'hover:border-white/40');
            t.classList.add('border-white/60');
          } else {
            t.classList.remove('border-white/60');
            t.classList.add('border-white/20', 'hover:border-white/40');
          }
        });
      }
    });
  });

  // Keyboard navigation
  document.addEventListener('keydown', (e) => {
    const mainImage = document.getElementById('gallery-main-image');
    if (!mainImage) return;

    const thumbs = document.querySelectorAll('.gallery-thumb');
    const current = Array.from(thumbs).findIndex(t =>
      t.getAttribute('data-src') === mainImage.src
    );

    if (e.key === 'ArrowRight' && current < thumbs.length - 1) {
      (thumbs[current + 1] as HTMLButtonElement).click();
    } else if (e.key === 'ArrowLeft' && current > 0) {
      (thumbs[current - 1] as HTMLButtonElement).click();
    }
  });
</script>
