<nav id="main-nav" class="px-[30px] md:px-[60px] py-[30px] flex items-center justify-between fixed top-0 left-0 right-0 z-[100] transition-all duration-300" aria-label="Navegação principal">
  <div>
    <a href="/" class="link-underline text-[28px] md:text-[40px] font-light text-white tracking-widest uppercase items-center flex gap-1">
      Mateus<span class="w-2 h-2 rounded-full bg-white mt-4"></span>
    </a>
  </div>
  <div class="flex items-center gap-6">
    <a href="#projects" class="hidden md:block link-underline text-sm font-space uppercase tracking-wider text-white/70 hover:text-white transition-colors">
      Projetos
    </a>
    <a href="mailto:matdasilvapinto@gmail.com" class="hidden md:flex text-sm font-space uppercase tracking-wider text-white border border-white/20 rounded-full px-6 py-2 hover:bg-white hover:text-black transition-colors cursor-pointer">
      Contato
    </a>
  </div>
</nav>

<script>
  // Navbar backdrop effect
  const nav = document.getElementById('main-nav');
  let scrolled = false;

  const updateNavbar = () => {
    const isScrolled = window.scrollY > 50;
    if (isScrolled !== scrolled) {
      scrolled = isScrolled;
      if (scrolled) {
        nav?.classList.add('backdrop-blur-md', 'bg-black/30');
        nav?.classList.remove('bg-transparent');
      } else {
        nav?.classList.remove('backdrop-blur-md', 'bg-black/30');
        nav?.classList.add('bg-transparent');
      }
    }
  };

  window.addEventListener('scroll', updateNavbar);
  updateNavbar();
</script>
